TWIN_STUDIO_EMAIL_MODE=console
TWIN_STUDIO_SMTP_HOST=
TWIN_STUDIO_SMTP_PORT=587
TWIN_STUDIO_SMTP_SECURE=false
TWIN_STUDIO_SMTP_USER=
TWIN_STUDIO_SMTP_PASSWORD=
TWIN_STUDIO_EMAIL_FROM=noreply@example.org
TWIN_STUDIO_EMAIL_FROM_NAME=Open Local Digital Twin
TWIN_STUDIO_EMAIL_REPLY_TO=

# PostGIS concurrency for local visual smoke and one-city deployments.
TWIN_STUDIO_DATABASE_POOL_SIZE=12
TWIN_STUDIO_DATABASE_CONNECT_TIMEOUT_MS=15000

# Dev/smoke-only credentials used by npm run test:visual-routes-smoke.
TWIN_STUDIO_SMOKE_EMAIL=smoke@polisplexity.test
TWIN_STUDIO_SMOKE_PASSWORD=<set-local-smoke-password>
TWIN_STUDIO_SMOKE_CITY_ID=demo-city
TWIN_STUDIO_SMOKE_BASE_URL=http://127.0.0.1:4192

# Optional compatibility fallback
EMAIL_HOST_PASSWORD=
